if [[ -e ${WKD%/}/.head ]]; then
    [[ TRACE -eq 0 ]] || {
        mkdir -p "${THREAD%/}/$$/$SIGTS"
        cp -p "${WKD%/}/.head" "${THREAD%/}/$$/$SIGTS/$((++HEAD))"
    }
    . "${WKD%/}/.head" && rm "${WKD%/}/.head"
else
    . .setup
    [[ $SLEEP == */* ]] && SLEEP="$(<$SLEEP)"
    sleep $SLEEP || sleep 1
fi
